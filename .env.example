# ============================================================
# Glanzoo — Environment Variables Template
# Copy this to .env and fill in ALL values before deploying
# ============================================================

# ============================================
# DATABASE — PostgreSQL (REQUIRED)
# ============================================
# Hostinger Business does NOT include PostgreSQL.
# Use Neon.tech (free) — https://neon.tech
#   1. Sign up → Create Project → Copy connection string
#   2. Paste below — must include ?sslmode=require
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require&connection_limit=10&pool_timeout=20"

# ============================================
# APPLICATION
# ============================================
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
NEXT_PUBLIC_APP_NAME="Glanzoo"
NODE_ENV="production"

# ============================================
# AUTHENTICATION (NextAuth v5)
# ============================================
# REQUIRED — generate with: openssl rand -base64 32
AUTH_SECRET="CHANGE_THIS_generate_with_openssl_rand_base64_32"
AUTH_TRUST_HOST=true

# ============================================
# EMAIL — Brevo SMTP (REQUIRED)
# ============================================
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=a5757a001@smtp-brevo.com
SMTP_PASS="YOUR_BREVO_SMTP_PASSWORD"
EMAIL_FROM=glanzoo8872@gmail.com

# ============================================
# PAYMENT GATEWAY (Razorpay)
# ============================================
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"
RAZORPAY_WEBHOOK_SECRET="CHANGE_THIS_generate_with_openssl_rand_hex_32"

# ============================================
# FILE STORAGE (Cloudinary) — REQUIRED
# ============================================
# Files uploaded locally are wiped on every redeploy!
# Get free credentials at: cloudinary.com
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ============================================
# SHIPPING (iThink Logistics)
# ============================================
ITHINK_API_KEY="your-ithink-api-key"

# ============================================
# ADMIN (Initial setup — change immediately!)
# ============================================
ADMIN_EMAIL="admin@glanzoo.com"
ADMIN_PASSWORD="CHANGE_THIS_IMMEDIATELY"
